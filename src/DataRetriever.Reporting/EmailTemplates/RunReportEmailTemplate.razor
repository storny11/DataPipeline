@* Defines the common email layout for status, issues, and service-specific tables. *@
@using System.Globalization
@using DataRetriever.Execution
@using DataRetriever.Reporting
@using Microsoft.AspNetCore.Components

<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
</head>
<body style="@BodyStyle" bgcolor="#f5f7fb">
    <table width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#f5f7fb" style="@OuterTableStyle">
        <tbody>
            <tr>
                <td align="center" style="@OuterCellStyle">
                    <table width="1180" align="center" cellspacing="0" cellpadding="0" border="0" style="@ContainerTableStyle">
                        <tbody>
                            <tr>
                                <td>
                                    <table width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" style="@PanelTableStyle">
                                        <tbody>
                                            <tr>
                                                <td height="4" bgcolor="#2557a7" style="@HeaderAccentStyle">&nbsp;</td>
                                            </tr>
                                            <tr>
                                                <td style="@HeaderContentStyle">
                                                    <div style="@EyebrowStyle">DATA RETRIEVAL REPORT</div>
                                                    <div style="@TitleStyle">@StatusHeading</div>
                                                    <table cellspacing="0" cellpadding="0" border="0" style="@StatusTableStyle">
                                                        <tbody>
                                                            <tr>
                                                                <td bgcolor="@StatusBackground" style="@StatusPillStyle">@Report.Status</td>
                                                                <td width="12" style="@TinySpacerStyle">&nbsp;</td>
                                                                <td style="@HeaderMetaTextStyle">Run @Report.RunId</td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </td>
                            </tr>

                            <tr><td height="16" style="@SpacerStyle">&nbsp;</td></tr>

                            <tr>
                                <td>
                                    <table width="100%" cellspacing="0" cellpadding="0" border="0" style="@SummaryTableStyle">
                                        <tbody>
                                            <tr>
                                                <td style="@SummaryCellStyle"><strong>Run id</strong><br />@Report.RunId</td>
                                                <td style="@SummaryCellStyle"><strong>Started</strong><br />@FormatDate(Report.StartedAt)</td>
                                                <td style="@SummaryCellStyle"><strong>Completed</strong><br />@FormatDate(Report.CompletedAt)</td>
                                            </tr>
                                            @if (DisplayStats)
                                            {
                                                <tr>
                                                    <td style="@SummaryCellStyle"><strong>Warnings</strong><br />@Report.WarningCount</td>
                                                    <td style="@SummaryCellStyle"><strong>Errors</strong><br />@Report.ErrorCount</td>
                                                    <td style="@SummaryCellStyle"><strong>Report tables</strong><br />@Report.Tables.Count</td>
                                                </tr>
                                                @for (var index = 0; index < Report.Summary.Count; index += 3)
                                                {
                                                    <tr>
                                                        @for (var offset = 0; offset < 3; offset++)
                                                        {
                                                            var metricIndex = index + offset;
                                                            if (metricIndex < Report.Summary.Count)
                                                            {
                                                                var metric = Report.Summary[metricIndex];
                                                                <td style="@SummaryCellStyle"><strong>@metric.Label</strong><br />@metric.Value</td>
                                                            }
                                                            else
                                                            {
                                                                <td style="@SummaryCellStyle">&nbsp;</td>
                                                            }
                                                        }
                                                    </tr>
                                                }
                                            }
                                        </tbody>
                                    </table>
                                </td>
                            </tr>

                            @if (Errors.Count > 0)
                            {
                                <tr><td height="18" style="@SpacerStyle">&nbsp;</td></tr>
                                <tr>
                                    <td>
                                        <table width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" style="@PanelTableStyle">
                                            <tbody>
                                                <tr>
                                                    <td width="4" bgcolor="#d92d20" style="@SectionAccentStyle">&nbsp;</td>
                                                    <td style="@SectionContentStyle">
                                                        <div style="@SectionHeadingStyle">Errors</div>
                                                        <div style="@SectionCaptionStyle">These items need attention before the run can be treated as clean.</div>
                                                        <IssuesTable Issues="Errors" />
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            }

                            @if (Warnings.Count > 0)
                            {
                                <tr><td height="18" style="@SpacerStyle">&nbsp;</td></tr>
                                <tr>
                                    <td>
                                        <table width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" style="@PanelTableStyle">
                                            <tbody>
                                                <tr>
                                                    <td width="4" bgcolor="#f79009" style="@SectionAccentStyle">&nbsp;</td>
                                                    <td style="@SectionContentStyle">
                                                        <div style="@SectionHeadingStyle">Warnings</div>
                                                        <div style="@SectionCaptionStyle">The run completed, but these rows or fields should be reviewed.</div>
                                                        <IssuesTable Issues="Warnings" />
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            }

                            @foreach (var table in Report.Tables)
                            {
                                <tr><td height="18" style="@SpacerStyle">&nbsp;</td></tr>
                                <tr>
                                    <td>
                                        <table width="100%" cellspacing="0" cellpadding="0" border="0" bgcolor="#ffffff" style="@PanelTableStyle">
                                            <tbody>
                                                <tr>
                                                    <td width="4" bgcolor="#2557a7" style="@SectionAccentStyle">&nbsp;</td>
                                                    <td style="@SectionContentStyle">
                                                        <div style="@SectionHeadingStyle">@table.Title</div>
                                                        <div style="@SectionCaptionStyle">@table.Rows.Count rows</div>
                                                        <ReportTable Table="table" />
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </td>
            </tr>
        </tbody>
    </table>
</body>
</html>

@code {
    [Parameter, EditorRequired]
    public RunReport Report { get; set; } = null!;

    [Parameter]
    public bool DisplayStats { get; set; }

    private const string BodyStyle = "margin:0; padding:0; background-color:#f5f7fb; color:#101828; font-family:Segoe UI, Arial, sans-serif;";
    private const string OuterTableStyle = "width:100%; background-color:#f5f7fb; border-collapse:collapse; mso-table-lspace:0pt; mso-table-rspace:0pt;";
    private const string OuterCellStyle = "padding:28px 14px;";
    private const string ContainerTableStyle = "width:1180px; border-collapse:collapse; mso-table-lspace:0pt; mso-table-rspace:0pt;";
    private const string PanelTableStyle = "width:100%; background-color:#ffffff; border:1px solid #d7dde8; border-collapse:collapse; mso-table-lspace:0pt; mso-table-rspace:0pt;";
    private const string HeaderAccentStyle = "height:4px; font-size:1px; line-height:4px; mso-line-height-rule:exactly; background-color:#2557a7;";
    private const string HeaderContentStyle = "padding:22px 24px 24px 24px; background-color:#ffffff;";
    private const string EyebrowStyle = "font-size:13px; line-height:18px; color:#52627a; font-weight:700; mso-line-height-rule:exactly;";
    private const string TitleStyle = "padding-top:6px; font-size:25px; line-height:34px; color:#111827; font-weight:700; mso-line-height-rule:exactly;";
    private const string StatusTableStyle = "margin-top:14px; border-collapse:collapse; mso-table-lspace:0pt; mso-table-rspace:0pt;";
    private const string HeaderMetaTextStyle = "font-size:13px; line-height:20px; color:#667085; mso-line-height-rule:exactly;";
    private const string TinySpacerStyle = "font-size:1px; line-height:1px;";
    private const string SpacerStyle = "font-size:1px; line-height:1px; mso-line-height-rule:exactly;";
    private const string SummaryTableStyle = "width:100%; border-collapse:collapse; mso-table-lspace:0pt; mso-table-rspace:0pt;";
    private const string SummaryCellStyle = "border:1px solid #d7dde8; background-color:#ffffff; padding:13px 15px; font-size:13px; line-height:20px; color:#344054; mso-line-height-rule:exactly;";
    private const string SectionAccentStyle = "width:4px; font-size:1px; line-height:1px;";
    private const string SectionContentStyle = "padding:18px; background-color:#ffffff;";
    private const string SectionHeadingStyle = "font-size:18px; line-height:25px; color:#1d2939; font-weight:700; mso-line-height-rule:exactly;";
    private const string SectionCaptionStyle = "padding-top:4px; padding-bottom:14px; font-size:13px; line-height:19px; color:#667085; mso-line-height-rule:exactly;";

    private IReadOnlyList<RunReportIssue> Warnings =>
        Report.Issues.Where(issue => issue.Severity == StepIssueSeverity.Warning).ToList();

    private IReadOnlyList<RunReportIssue> Errors =>
        Report.Issues.Where(issue => issue.Severity == StepIssueSeverity.Error).ToList();

    private string StatusHeading =>
        Report.ErrorCount > 0
            ? "Run completed with errors"
            : Report.WarningCount > 0
                ? "Run completed with warnings"
                : "Run completed successfully";

    private string StatusPillStyle =>
        $"padding:5px 10px; font-size:13px; line-height:18px; font-weight:700; color:{StatusForeground}; background-color:{StatusBackground}; mso-line-height-rule:exactly;";

    private string StatusForeground =>
        Report.ErrorCount > 0 ? "#912018" : Report.WarningCount > 0 ? "#93370d" : "#05603a";

    private string StatusBackground =>
        Report.ErrorCount > 0 ? "#fee4e2" : Report.WarningCount > 0 ? "#fef0c7" : "#d1fadf";

    private static string FormatDate(DateTimeOffset value) => value.ToString("yyyy-MM-dd HH:mm:ss zzz", CultureInfo.InvariantCulture);
}
