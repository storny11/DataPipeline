@* Renders any service-provided report table as an email-safe grid. *@
@using DataRetriever.Reporting
@using Microsoft.AspNetCore.Components

@if (Table.Rows.Count == 0)
{
    <table width="100%" cellspacing="0" cellpadding="0" border="0" style="@EmptyStateTableStyle">
        <tbody>
            <tr>
                <td bgcolor="#f8fafc" style="@EmptyStateCellStyle">No rows in this section.</td>
            </tr>
        </tbody>
    </table>
}
else
{
    <table width="100%" cellspacing="0" cellpadding="0" border="0" style="@GridStyle">
        <thead>
            <tr>
                @foreach (var column in Table.Columns)
                {
                    <th align="@Align(column.Alignment)" bgcolor="#eef4ff" style="@HeaderCellStyle">@column.Header.ToUpperInvariant()</th>
                }
            </tr>
        </thead>
        <tbody>
            @for (var index = 0; index < Table.Rows.Count; index++)
            {
                var row = Table.Rows[index];
                var rowBackground = RowBackground(index);
                <tr>
                    @foreach (var column in Table.Columns)
                    {
                        <td align="@Align(column.Alignment)" bgcolor="@rowBackground" style="@CellStyleFor(column.Alignment, rowBackground)">@Value(row, column.Key)</td>
                    }
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter, EditorRequired]
    public RunReportTable Table { get; set; } = null!;

    private const string GridStyle = "border-collapse:collapse; width:100%; background-color:#ffffff; border:1px solid #d7dde8; mso-table-lspace:0pt; mso-table-rspace:0pt;";
    private const string HeaderCellStyle = "background-color:#eef4ff; border:1px solid #d7dde8; padding:10px 12px; font-size:12px; line-height:17px; color:#1f3a5f; font-weight:700; mso-line-height-rule:exactly;";
    private const string CellStyle = "border:1px solid #e4e7ec; padding:10px 12px; font-size:13px; line-height:19px; color:#344054; vertical-align:top; mso-line-height-rule:exactly;";
    private const string NumberCellStyle = CellStyle + " text-align:right;";
    private const string EmptyStateTableStyle = "width:100%; border-collapse:collapse; border:1px solid #d7dde8; mso-table-lspace:0pt; mso-table-rspace:0pt;";
    private const string EmptyStateCellStyle = "padding:12px 14px; background-color:#f8fafc; color:#475467; font-size:13px; line-height:19px; mso-line-height-rule:exactly;";

    private static string RowBackground(int index) => index % 2 == 0 ? "#ffffff" : "#f8fafc";

    private static string Value(IReadOnlyDictionary<string, string?> row, string key)
    {
        return row.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value)
            ? value
            : "-";
    }

    private static string Align(RunReportColumnAlignment alignment)
    {
        return alignment switch
        {
            RunReportColumnAlignment.Right => "right",
            RunReportColumnAlignment.Center => "center",
            _ => "left"
        };
    }

    private static string CellStyleFor(RunReportColumnAlignment alignment, string backgroundColor)
    {
        string style = alignment == RunReportColumnAlignment.Right
            ? NumberCellStyle
            : CellStyle;

        return $"{style} background-color:{backgroundColor};";
    }
}
