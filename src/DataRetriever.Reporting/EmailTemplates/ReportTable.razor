@* Renders any service-provided report table as an email-safe grid. *@
@using DataRetriever.Reporting
@using Microsoft.AspNetCore.Components

@if (Table.Rows.Count == 0)
{
    <p style="@EmptyStateStyle">No rows in this section.</p>
}
else
{
    <table width="100%" cellspacing="0" cellpadding="0" style="@GridStyle">
        <thead>
            <tr>
                @foreach (var column in Table.Columns)
                {
                    <th align="@Align(column.Alignment)" style="@HeaderCellStyle">@column.Header</th>
                }
            </tr>
        </thead>
        <tbody>
            @for (var index = 0; index < Table.Rows.Count; index++)
            {
                var row = Table.Rows[index];
                <tr style="background-color:@RowBackground(index);">
                    @foreach (var column in Table.Columns)
                    {
                        <td align="@Align(column.Alignment)" style="@CellStyleFor(column.Alignment)">@Value(row, column.Key)</td>
                    }
                </tr>
            }
        </tbody>
    </table>
}

@code {
    [Parameter, EditorRequired]
    public RunReportTable Table { get; set; } = null!;

    private const string GridStyle = "border-collapse:collapse; width:100%; background-color:#ffffff; border:1px solid #d7dde8;";
    private const string HeaderCellStyle = "background-color:#eef4ff; border:1px solid #d7dde8; padding:10px 12px; font-size:12px; line-height:17px; color:#1f3a5f; font-weight:700; text-transform:uppercase; letter-spacing:0;";
    private const string CellStyle = "border:1px solid #e4e7ec; padding:10px 12px; font-size:13px; line-height:19px; color:#344054; vertical-align:top;";
    private const string NumberCellStyle = CellStyle + " text-align:right;";
    private const string EmptyStateStyle = "margin:0; padding:12px 14px; background-color:#f8fafc; border:1px solid #d7dde8; color:#475467; font-size:13px; border-radius:8px;";

    private static string RowBackground(int index) => index % 2 == 0 ? "#ffffff" : "#f8fafc";

    private static string Value(IReadOnlyDictionary<string, string?> row, string key)
    {
        return row.TryGetValue(key, out var value) && !string.IsNullOrWhiteSpace(value)
            ? value
            : "-";
    }

    private static string Align(RunReportColumnAlignment alignment)
    {
        return alignment switch
        {
            RunReportColumnAlignment.Right => "right",
            RunReportColumnAlignment.Center => "center",
            _ => "left"
        };
    }

    private static string CellStyleFor(RunReportColumnAlignment alignment)
    {
        return alignment == RunReportColumnAlignment.Right
            ? NumberCellStyle
            : CellStyle;
    }
}
